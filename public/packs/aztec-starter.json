    {
      "id": "warrior-cosmos",
      "entityType": "motif",
      "name": "Warrior as Cosmic Agent",
      "slug": "warrior-cosmos",
      "mythologyIds": ["aztec"],
      "summary": "Warriors serve the cosmos by providing victims for sacrifice and maintaining cosmic order.",
      "category": "social",
      "description": "Warfare is not merely political but cosmological essential. Warriors capture victims for sacrifice, ensuring the sun continues moving and preventing apocalypse. The warrior ideal embodies cosmic responsibility.",
      "interpretation": "Aztec integration of military, religious, and cosmic functions into the warrior role.",
      "tags": ["warfare", "warrior", "cosmos", "sacrifice"],
