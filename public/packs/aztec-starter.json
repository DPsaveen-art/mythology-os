      "id": "five-suns-creation",
      "entityType": "story",
      "name": "The Five Suns Creation Cycle",
      "slug": "five-suns-creation",
      "mythologyIds": ["aztec"],
      "summary": "Five successive creation cycles, each ending in cosmic destruction, with the current fifth sun requiring human sacrifice.",
      "storyType": "cosmogony",
      "description": "The world has been created and destroyed five times. Each sun (creation cycle) was ruled by different deities and ended in catastrophe through floods, fires, storms, or darkness. The current fifth sun (Tonatiuh) requires human blood to continue moving across the sky.",
      "sequenceSummary": "First Sun (jaguars) → Second Sun (wind) → Third Sun (fire rain) → Fourth Sun (water) → Fifth Sun (current, requires blood)",
      "themes": ["cosmic cycles", "creation and destruction", "sacrifice", "cosmic maintenance"],
      "outcomeSummary": "Current world maintained through human sacrifice to keep the sun moving and prevent apocalypse.",
