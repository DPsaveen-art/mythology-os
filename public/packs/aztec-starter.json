    },
    {
      "id": "blood-sacrifice",
      "entityType": "motif",
      "name": "Blood Sacrifice for Cosmic Maintenance",
      "slug": "blood-sacrifice",
      "mythologyIds": ["aztec"],
      "summary": "Human blood sacrifice essential to sustain the gods and prevent cosmic catastrophe.",
      "category": "ritual",
      "description": "The gods require human blood, particularly the heart, to continue their cosmic functions. Without sacrifice, the sun would stop moving and the world would be destroyed. This justifies warfare and ritual killing.",
      "interpretation": "Central Aztec belief system linking human action directly to cosmic survival and order.",
      "tags": ["sacrifice", "blood", "cosmos", "essential"],
      "status": "active",
      "confidence": "certain",
      "sourceRefIds": [],
      "noteIds": [],
      "createdAt": "2025-01-01T00:00:00Z",
      "updatedAt": "2025-01-01T00:00:00Z"
    },
    {
      "id": "duality-balance",
      "entityType": "motif",
      "name": "Cosmic Duality and Balance",
      "slug": "duality-balance",
      "mythologyIds": ["aztec"],
      "summary": "Opposing forces must remain in balance to maintain cosmic order.",
      "category": "philosophical",
      "description": " opposing forces like day/night, life/death, creation/destruction, Quetzalcoatl/Tezcatlipoca must remain balanced. Imbalance leads to cosmic catastrophe and destruction.",
      "interpretation": "Aztec philosophical understanding of the universe as maintained through dynamic tension between opposites.",
      "tags": ["duality", "balance", "opposites", "cosmos"],
      "status": "active",
      "confidence": "certain",
