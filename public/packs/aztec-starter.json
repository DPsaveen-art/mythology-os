  "motifs": [
    {
      "id": "cosmic-cycles",
      "entityType": "motif",
      "name": "Cosmic Creation Cycles",
      "slug": "cosmic-cycles",
      "mythologyIds": ["aztec"],
      "summary": "World undergoes repeated cycles of creation and destruction.",
      "category": "cosmological",
      "description": "The world has been created and destroyed five times, each cycle ending in catastrophe. The current fifth sun requires constant maintenance through sacrifice to prevent its destruction.",
      "interpretation": "Aztec understanding of cosmic time as cyclical rather than linear, with constant tension between creation and destruction.",
      "tags": ["cosmos", "cycles", "creation", "destruction"],
      "status": "active",
      "confidence": "certain",
      "sourceRefIds": [],
      "noteIds": [],
      "createdAt": "2025-01-01T00:00:00Z",
