      "id": "source-rom-1",
      "title": "Aeneid",
      "authorOrTradition": "Virgil",
      "sourceType": "primary",
      "dateOrPeriod": "c. 29-19 BCE",
      "description": "Epic poem telling the story of Aeneas and the founding of Rome.",
      "citation": "Virgil. Aeneid. Trans. R. Fagles. Penguin, 2006.",
      "reliability": "high",
      "notes": "Primary source for Roman foundation mythology.",
      "createdAt": "2025-01-01T00:00:00Z",
      "updatedAt": "2025-01-01T00:00:00Z"
    },
    {
      "id": "source-rom-2",
      "title": "Ab Urbe Condita",
      "authorOrTradition": "Livy",
      "sourceType": "primary",
      "dateOrPeriod": "c. 27-9 BCE",
      "description": "History of Rome from its foundation to Augustan times.",
      "citation": "Livy. Ab Urbe Condita. Trans. B.O. Foster. Loeb, 1919.",
      "reliability": "high",
      "notes": "Main source for early Roman history and mythology.",
      "createdAt": "2025-01-01T00:00:00Z",
      "updatedAt": "2025-01-01T00:00:00Z"
    },
    {
      "id": "source-rom-3",
      "title": "Metamorphoses",
      "authorOrTradition": "Ovid",
      "sourceType": "primary",
      "dateOrPeriod": "c. 8 CE",
      "description": "Poetic work containing Roman versions of Greek myths and Roman legends.",
      "citation": "Ovid. Metamorphoses. Trans. A.D. Melville. Oxford, 1986.",
      "reliability": "high",
      "notes": "Important source for Roman mythological narratives.",
      "createdAt": "2025-01-01T00:00:00Z",
      "updatedAt": "2025-01-01T00:00:00Z"
    },
